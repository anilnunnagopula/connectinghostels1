# Server environment variables
# Copy this to .env and fill in the values. NEVER commit .env to git.

# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=your_mongodb_connection_string

# Auth
JWT_SECRET=a_long_random_secret_at_least_32_chars

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (for password reset)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# OTP / SMS
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=your_twilio_phone_number

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret from Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# AI (server-side only — do NOT put this in client env)
GEMINI_API_KEY=your_gemini_api_key

# Observability (optional but recommended)
SENTRY_DSN=your_sentry_dsn_from_sentry_io

# Frontend URL (for password reset emails)
FRONTEND_URL=http://localhost:3000

# Redis — enables caching + BullMQ async email queue (optional but recommended)
# Free tier: https://upstash.com → Create Redis → copy the "Redis URL"
REDIS_URL=redis://default:your_password@your-host.upstash.io:6379

# BetterStack Logs (optional — enables structured log shipping to BetterStack)
# Setup: logs.betterstack.com → Sources → Create → copy "Source Token"
# Configure uptime monitor: betterstack.com → Uptime → New monitor → URL = https://your-api/health
BETTERSTACK_SOURCE_TOKEN=your_betterstack_source_token

# Cloudflare R2 image storage (optional — critical for production)
# Without R2, uploaded images live on local disk and are LOST on server restart.
# Setup: dash.cloudflare.com → R2 → Create bucket → API Tokens → Object R+W
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
