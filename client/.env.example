# Client environment variables
# Copy this to .env and fill in the values.
# WARNING: Everything here is compiled into the public JS bundle — never put secrets here.

# Backend API URL
REACT_APP_API_URL=http://localhost:5000

# Google OAuth Client ID (public by design — required for the Sign In with Google button)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id

# Observability (optional — get DSN from sentry.io after creating a React project)
REACT_APP_SENTRY_DSN=your_sentry_dsn_from_sentry_io
